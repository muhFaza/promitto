{
  "name": "promitto-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Promitto backend — Express + Drizzle + SQLite",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "cli:create-superuser": "tsx src/cli/create-superuser.ts",
    "cli:reset-superuser-password": "tsx src/cli/reset-superuser-password.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@inquirer/prompts": "^7.0.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.5.0",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^5.0.6",
    "drizzle-orm": "^0.36.1",
    "express": "^4.21.1",
    "libphonenumber-js": "^1.11.14",
    "luxon": "^3.5.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "engines": {
    "node": ">=20"
  }
}
