NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-32-plus-random-chars-please
# Optional: distinct HMAC key for CSRF tokens. Falls back to SESSION_SECRET when unset.
# Recommended in production: openssl rand -base64 48
# CSRF_SECRET=replace-with-a-different-32-plus-random-chars
DATABASE_PATH=./data/promitto.db
SESSIONS_DIR=./data/sessions
LOG_LEVEL=debug
DEFAULT_TIMEZONE=Asia/Jakarta
TRUST_PROXY=false
