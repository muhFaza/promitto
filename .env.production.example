# Copy to .env and fill in for `docker compose -f docker-compose.prod.yml up`.
# Generate fresh secrets with:  openssl rand -base64 48
SESSION_SECRET=replace-me-with-32-plus-random-chars
# Distinct HMAC key for CSRF tokens. Falls back to SESSION_SECRET when unset, but
# production should set this to a different value so the two HMAC purposes don't
# share a key. Rotating invalidates all outstanding CSRF cookies on next login.
CSRF_SECRET=replace-me-with-a-different-32-plus-random-chars
APP_URL=https://wa.muhfaza.my.id
DEFAULT_TIMEZONE=Asia/Jakarta
LOG_LEVEL=info
